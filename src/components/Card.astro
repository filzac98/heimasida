---
const { title, link, image } = Astro.props;
---

<a href={link} class="card">
  <h2>{title}</h2>
  {image && <img src={image} alt={title} class="card-image" />}
</a>

<style>
  .card {
    background-color: var(--card-bg);
    color: var(--text-color);
    text-align: center;
    padding: 1rem;
    max-width: 100%;
    margin: auto;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    text-decoration: none;
    transition:
      transform 0.3s,
      box-shadow 0.3s;
  }

  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 6px 10px rgba(0, 0, 0, 0.2);
  }

  .card h2 {
    font-size: 1.5rem;
    margin: 0.5rem 0;
  }

  .card-image {
    max-width: 100%; /* Ensures the image doesn't exceed the card's width */
    max-height: 650px;
    height: auto; /* Keeps the image's aspect ratio */
    border-radius: 8px;
    margin-top: 0.5rem;
  }
</style>
